# ============================================================
# DATABASE (Supabase PostgreSQL)
# ============================================================

# Runtime connection — PgBouncer Transaction mode (port 6543)
# Used by the app at runtime via @prisma/adapter-pg
# The ?pgbouncer=true param is required for PgBouncer compatibility
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[YOUR-REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection — Session mode (port 5432)
# Used ONLY by the ingest script (scripts/ingest.ts) which needs $transaction() support
# NOT needed by the app at runtime — Railway/production does not require this unless running ingest
# Find this in Supabase → Project → Settings → Database → Connection string → URI (not pooler)
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# ============================================================
# SUPABASE
# ============================================================
SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ============================================================
# CLERK AUTHENTICATION
# ============================================================
# Use pk_test_* / sk_test_* for development, pk_live_* / sk_live_* for production
CLERK_PUBLISHABLE_KEY="pk_test_your-clerk-publishable-key"
CLERK_SECRET_KEY="sk_test_your-clerk-secret-key"
CLERK_WEBHOOK_SECRET="whsec_your-webhook-secret"

# ============================================================
# ARCJET SECURITY (optional)
# ============================================================
ARCJET_KEY="ajkey_your-arcjet-key"
ARCJET_ENV="development"

# ============================================================
# APP
# ============================================================
NODE_ENV="development"
